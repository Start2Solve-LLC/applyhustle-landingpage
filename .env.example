# Base URL of the main ApplyHustle app (frontend/ — Vite dev server runs on port 5173).
# All Login / Get Started / pricing CTAs link into this app: /signin, /signup, /ats-checker.
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Public URL of this landing site itself — the canonical production domain.
# Drives canonical tags, sitemap, robots, OG/Twitter URLs, and JSON-LD.
# MUST be the real https domain in production, e.g. https://applyhustle.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SEO indexing override (optional). Leave unset for automatic behavior:
# production indexes, preview/staging/dev are noindex. Set to force a value.
#   true  = allow search engines to index this deployment
#   false = block indexing (noindex + robots.txt disallow all)
# NEXT_PUBLIC_SEO_INDEX=true

# ── Sentry (browser error monitoring) — optional ──────────────────────────
# On this static-export site only the BROWSER SDK runs (no server runtime).
# Without a DSN, Sentry is a no-op. Get the DSN from your Sentry project.
NEXT_PUBLIC_SENTRY_DSN=
# Opt in to Session Replay (adds ~40KB to the client bundle). Default: off.
# NEXT_PUBLIC_SENTRY_REPLAY=true
# Override the Sentry environment tag (defaults to NODE_ENV).
# NEXT_PUBLIC_SENTRY_ENV=production

# Source-map upload at BUILD time (set these as CI secrets/variables, not here).
# Token needs the `project:releases` scope. Without them, upload is skipped.
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=applyhustle-landing
# SENTRY_AUTH_TOKEN=   # secret — never commit
